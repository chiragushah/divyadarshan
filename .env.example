# ─── MONGODB ATLAS ───────────────────────────────────────
# Create free cluster at mongodb.com/atlas
# Connection string format:
# mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/divyadarshan?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/divyadarshan?retryWrites=true&w=majority

# ─── NEXTAUTH ────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run_openssl_rand_base64_32_and_paste_here

# ─── GOOGLE OAUTH ────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── AI PROVIDERS ────────────────────────────────────────
# Groq  → console.groq.com         (free tier)
# Gemini → aistudio.google.com     (free tier)
# Claude → console.anthropic.com
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=sk-ant-your_claude_key_here

# ─── APP CONFIG ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DivyaDarshan

# ─── FINVERSE ────────────────────────────────────────────
NEXT_PUBLIC_FINVERSE_URL=https://finverse.app
